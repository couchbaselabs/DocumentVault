{
  "name": "@couchbaselabs/couchbase-lite",
  "repository": {
    "type": "git",
    "url": "https://github.com/couchbaselabs/couchbase-lite-js.git"
  },
  "displayName": "Couchbase Lite for JavaScript",
  "type": "module",
  "version": "0.3.3",
  "browser": "./dist/couchbase-lite.js",
  "main": "./dist/couchbase-lite.cjs.js",
  "module": "./dist/couchbase-lite.es.js",
  "scripts": {
    "build": "ohm generateBundles --esm --withTypes src/query/N1QL.ohm && tsc && vite build",
    "dev": "vite",
    "test": "vitest --run",
    "test:browser": "vitest --run --browser",
    "test:watch": "vitest --watch",
    "lint": "eslint src; eslint examples; eslint test",
    "lint:fix": "eslint --fix src",
    "doc": "typedoc --excludeInternal src/couchbase-lite.ts",
    "build-grammar": "ohm generateBundles --esm --withTypes src/query/N1QL.ohm"
  },
  "exports": {
    "types": "./dist/couchbase-lite.d.ts",
    "browser": "./dist/couchbase-lite.js",
    "import": "./dist/couchbase-lite.es.js",
    "require": "./dist/couchbase-lite.cjs.js"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@date-fns/tz": "^1.3.1",
    "@foxglove/crc": "^1.0.1",
    "@logtape/logtape": "^1.0.4",
    "buffer": "^6.0.3",
    "date-fns": "^4.1.0",
    "dexie": "^4.0.11",
    "isomorphic-ws": "^5.0.0",
    "ohm-js": "^17.2.1",
    "pako": "^1.0.11",
    "regexp.escape": "^2.0.1",
    "sha.js": "^2.4.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.32.0",
    "@ohm-js/cli": "^2.0.1",
    "@stylistic/eslint-plugin": "^4.4.1",
    "@types/node": "^22.17.0",
    "@types/pako": "^1.0.7",
    "@types/regexp.escape": "^2.0.0",
    "@types/sha.js": "^2.4.4",
    "@types/ws": "^8.18.1",
    "@vitest/browser": "^3.2.4",
    "ajv": "^8.17.1",
    "eslint": "^9.32.0",
    "fake-indexeddb": "^6.0.1",
    "globals": "^16.3.0",
    "playwright": "^1.54.2",
    "typedoc": "^0.28.9",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.39.0",
    "vite": "^6.3.5",
    "vite-plugin-dts": "^4.5.4",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.2.4"
  }
}
