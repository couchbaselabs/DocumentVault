# Couchbase Sync Gateway Configuration
# Copy this file to .env and fill in your values

# App Services WebSocket URL (get this from Capella App Services dashboard)
# Format: wss://your-endpoint.apps.cloud.couchbase.com/your-database-name
VITE_SYNC_GATEWAY_URL=wss://your-app-services-url.apps.cloud.couchbase.com/retail-sync

# App Services User Credentials
VITE_SYNC_USERNAME=inventory-user
VITE_SYNC_PASSWORD=your-secure-password

# Optional: Enable/disable sync
VITE_ENABLE_SYNC=true
